{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ViDBA",
  "version": "0.4.0",
  "identifier": "com.linhnh285.vi-db-admin",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1424",
    "beforeDevCommand": "npm run dev --prefix ../frontend",
    "beforeBuildCommand": "npm run build --prefix ../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Vidba",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}